{
  "name": "astro-portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "journal:summary": "bun scripts/generate-journal-summaries.ts",
    "journal:summary:force-week": "bun scripts/generate-journal-summaries.ts --force --period week",
    "journal:index": "bun scripts/index-content.ts",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx --fix",
    "check": "astro check",
    "content:validate": "bun scripts/validate-content.ts",
    "verify": "bun run lint && bun run check && bun run content:validate && bun run build",
    "docs:diagrams": "bash scripts/render-plantuml.sh"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@hookform/resolvers": "^5.2.2",
    "@lancedb/lancedb": "^0.27.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xenova/transformers": "^2.17.2",
    "astro": "^6.1.7",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "0.469.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-3d": "^1.29.1",
    "react-hook-form": "^7.72.1",
    "satori": "^0.26.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.183.1",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "typescript-eslint": "^8.58.2"
  }
