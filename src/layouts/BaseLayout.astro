---
import { seo } from '@/lib/config';
import Navigation from "@/components/Navigation";
import { ReadingProgress } from "@/components/ReadingProgress";
import ScrollToTopClient from "@/components/ScrollToTop.client";
import { CommandPalette } from "@/components/CommandPalette";
import CodeCopy from "@/components/CodeCopy.astro";
import Schema from "@/components/seo/Schema.astro";
import GridBackground from "@/components/GridBackground.astro";
import Footer from "@/components/Footer.astro";
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	article?: boolean;
	publishDate?: Date;
	tags?: string[];
}

const { 
	title = seo.title, 
	description = seo.description, 
	image: propImage,
	article = false,
	publishDate,
	tags
} = Astro.props;

// Calculate dynamic OG image for articles
let ogImage = propImage || seo.image;
if (article) {
    const path = Astro.url.pathname.replace(/^\/|\/$/g, '');
    if (path.startsWith('blog/') || path.startsWith('journal/')) {
        ogImage = `/og/${path}.png`;
    }
}

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.published : true;
});

const journal = await getCollection('journal');

const blogPosts = posts.map(post => ({
  title: post.data.title,
  slug: post.id,
  description: post.data.description,
  type: 'blog' as const,
}));

const journalPosts = journal.map(post => ({
  title: post.data.title,
  slug: post.id,
  description: post.data.summary || '',
  type: 'journal' as const,
}));

const allPosts = [...blogPosts, ...journalPosts];

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://truongdq.com');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Primary Meta Tags -->
		<title>{title === seo.title ? title : `${title} | ${seo.title}`}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={article ? 'article' : 'website'} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(ogImage, Astro.url)} />

		<!-- JSON-LD Structured Data -->
		<Schema 
			type={article ? 'Article' : 'WebSite'}
			title={title}
			description={description}
			image={ogImage}
			publishDate={publishDate}
			tags={tags}
		/>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

		<ClientRouter />
		<!-- Resource hints -->
	</head>
	<body class="bg-background text-foreground antialiased min-h-screen flex flex-col">
		<ReadingProgress client:load />
		<GridBackground />
		<Navigation client:load transition:persist />
		<main class="flex-1">
			<slot />
		</main>
		<ScrollToTopClient client:load transition:persist />
		<CommandPalette client:idle transition:persist posts={allPosts} />
		<CodeCopy />
		<Footer />
	</body>
</html>
