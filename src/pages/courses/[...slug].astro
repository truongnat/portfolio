---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ArrowLeft, Clock, BookOpen, Tag, Play } from 'lucide-react';
import { seo } from '@/lib/config';
export const prerender = true;

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({
    params: { slug: course.id },
    props: course,
  }));
}

const course = Astro.props;
const { Content } = await render(course);

const levelColors: Record<string, string> = {
  beginner: 'bg-green-500/10 text-green-400 border-green-500/20',
  intermediate: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  advanced: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
};
const levelLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

const videos = course.data.videos || [];
---

<BaseLayout
  title={course.data.title}
  description={course.data.description}
  image={course.data.coverImage || seo.image}
>
  <div class="min-h-screen">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-12 pt-24">
      <div class="mb-8">
        <a
          href="/courses/"
          class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors duration-200 group"
        >
          <ArrowLeft className="h-4 w-4 transition-transform duration-200 group-hover:-translate-x-1" />
          Back to Courses
        </a>
      </div>

      <div class="lg:grid lg:grid-cols-12 lg:gap-12">
        <main class="lg:col-span-8 min-w-0">
          <header class="mb-12 border-b border-border/40 pb-12">
            <div class="flex flex-wrap gap-2 mb-6">
              {course.data.level && (
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium border ${levelColors[course.data.level] ?? ''}`}>
                  {levelLabel[course.data.level] ?? course.data.level}
                </span>
              )}
              {course.data.price && (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                  {course.data.price}
                </span>
              )}
              {course.data.status === 'coming-soon' && (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">
                  Coming Soon
                </span>
              )}
            </div>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6 text-foreground leading-tight">
              {course.data.title}
            </h1>

            {course.data.description && (
              <p class="text-xl text-muted-foreground mb-8 leading-relaxed">
                {course.data.description}
              </p>
            )}

            <div class="flex flex-wrap items-center gap-6 text-sm text-muted-foreground">
              {course.data.duration && (
                <div class="flex items-center gap-2">
                  <Clock className="h-4 w-4" />
                  <span>{course.data.duration}</span>
                </div>
              )}
              {course.data.tags && course.data.tags.length > 0 && (
                <div class="flex items-center gap-2 flex-wrap">
                  <Tag className="h-4 w-4" />
                  {course.data.tags.map((tag: string) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-secondary/50 text-secondary-foreground">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </header>

          {course.data.coverImage && (
            <div class="mb-12 rounded-2xl overflow-hidden shadow-xl">
              <img src={course.data.coverImage} alt={course.data.title} class="w-full h-64 object-cover" />
            </div>
          )}

          {/* Video Lessons */}
          {videos.length > 0 && (
            <section class="mb-12">
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
                <span class="h-8 w-1 bg-primary rounded-full"></span>
                Video Lessons
              </h2>
              <div class="space-y-6">
                {videos.map((video: { title: string; url: string; lesson?: number }, i: number) => (
                  <div class="rounded-xl border border-border/40 bg-card/30 overflow-hidden">
                    <div class="px-4 py-3 border-b border-border/40 flex items-center gap-3">
                      <div class="flex items-center justify-center w-7 h-7 rounded-full bg-primary/10 border border-primary/20">
                        <Play className="h-3 w-3 text-primary fill-primary" />
                      </div>
                      <span class="text-sm font-medium text-foreground">
                        Lesson {video.lesson ?? i + 1} — {video.title}
                      </span>
                    </div>
                    <video
                      controls
                      preload="metadata"
                      class="w-full aspect-video bg-black"
                      src={video.url}
                    >
                      Your browser does not support the video tag.
                    </video>
                  </div>
                ))}
              </div>
            </section>
          )}

          {/* Mobile Curriculum - shown below video, above article, on mobile/tablet only */}
          {course.data.modules && course.data.modules.length > 0 && (
            <details class="lg:hidden mb-8 rounded-xl border border-border/40 bg-card/30 backdrop-blur-sm overflow-hidden">
              <summary class="flex items-center gap-2 p-4 cursor-pointer font-semibold text-foreground select-none">
                <BookOpen className="h-4 w-4 text-primary" />
                Course Curriculum ({course.data.modules.reduce((acc: number, m: any) => acc + m.lessons.length, 0)} lessons)
                <span class="ml-auto text-xs text-muted-foreground">tap to expand</span>
              </summary>
              <div class="px-4 pb-4 space-y-4">
                {course.data.modules.map((mod: { title: string; lessons: string[] }, i: number) => (
                  <div>
                    <h4 class="text-sm font-semibold text-foreground mb-2">{i + 1}. {mod.title}</h4>
                    <ul class="space-y-1">
                      {mod.lessons.map((lesson: string, j: number) => (
                        <li class="text-xs text-muted-foreground flex items-start gap-2 py-1 border-b border-border/20 last:border-0">
                          <span class="text-primary/50 shrink-0 mt-0.5">{i+1}.{j+1}</span>
                          <span>{lesson}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </details>
          )}

          <article class="prose prose-lg dark:prose-invert max-w-none prose-headings:scroll-mt-24 prose-img:rounded-xl">
            <Content />
          </article>

          <footer class="mt-16 pt-8 border-t border-border">
            <a
              href="/courses/"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-secondary/50 hover:bg-secondary text-secondary-foreground text-sm font-medium transition-all"
            >
              <ArrowLeft className="h-4 w-4" />
              View all courses
            </a>
          </footer>
        </main>

        <aside class="hidden lg:block lg:col-span-4 pl-8">
          <div class="sticky top-24 space-y-6">
            {course.data.modules && course.data.modules.length > 0 && (
              <div class="rounded-xl border border-border/40 bg-card/30 backdrop-blur-sm p-6 shadow-sm">
                <h3 class="font-semibold text-foreground mb-4 flex items-center gap-2">
                  <BookOpen className="h-4 w-4 text-primary" />
                  Course Curriculum
                </h3>
                <div class="space-y-4 max-h-[calc(100vh-200px)] overflow-y-auto pr-1">
                  {course.data.modules.map((mod: { title: string; lessons: string[] }, i: number) => (
                    <div>
                      <h4 class="text-sm font-semibold text-foreground mb-2">
                        {i + 1}. {mod.title}
                      </h4>
                      <ul class="space-y-1">
                        {mod.lessons.map((lesson: string, j: number) => (
                          <li class="text-xs text-muted-foreground flex items-start gap-2 py-1 border-b border-border/20 last:border-0">
                            <span class="text-primary/50 shrink-0 mt-0.5">{i + 1}.{j + 1}</span>
                            <span>{lesson}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
