---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = true;
import { KnowledgeGraphClient } from '@/components/KnowledgeGraph.client';
import { getGraphData } from '@/lib/graph';

const graphData = await getGraphData();
---

<BaseLayout title="Knowledge Graph | Interactive Engineering Network" description="Explore the interconnected world of engineering, AI, and full-stack development through this interactive knowledge graph.">
	<main class="min-h-screen py-24 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
		<div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-primary/5 to-transparent pointer-events-none" />
		
		<div class="max-w-7xl mx-auto relative z-10">
			{/* Header */}
			<div class="mb-12 pt-8 max-w-3xl">
				<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 text-foreground text-deep-shadow">
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-foreground to-foreground/70">
						Knowledge
					</span>
					<br />
					<span class="text-primary">Network</span>
				</h1>
				<p class="text-xl text-muted-foreground leading-relaxed">
					An interactive visualization of how <span class="text-foreground font-medium">engineering concepts</span>, <span class="text-foreground font-medium">daily logs</span>, and <span class="text-foreground font-medium">blog posts</span> interconnect.
				</p>
			</div>

			<div class="mb-8 p-4 rounded-xl bg-blue-500/5 border border-blue-500/20 text-blue-200/80 text-sm font-mono flex items-start gap-3">
				<span class="p-1 bg-blue-500/20 rounded text-[10px] mt-0.5">TIP</span>
				<p>Scroll to zoom, drag to pan, and click nodes to dive into specific topics. High-density nodes represent core technical clusters.</p>
			</div>

			<KnowledgeGraphClient client:load data={graphData} />
		</div>
	</main>
</BaseLayout>

<style>
	.text-deep-shadow {
		text-shadow: 0 0 40px rgba(var(--primary), 0.2);
	}
</style>
