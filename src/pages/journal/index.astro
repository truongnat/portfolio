---
import { getCollection } from 'astro:content';
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import { JournalContent } from '@/components/JournalContent';

const logs = await getCollection('journal');

// Sort logs by date descending
const sortedLogs = logs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const mappedLogs = sortedLogs.map(log => ({
	slug: log.slug,
	title: log.data.title,
	date: log.data.date.toISOString(),
	type: log.data.type,
	summary: log.data.summary,
	tags: log.data.tags,
}));
---

<BaseLayout title="Journal | Engineering Logbook" description="My daily notes, weekly summaries, and long-term reflections on engineering and AI.">
	<main class="min-h-screen py-24 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
		{/* Background decorative elements */}
		<div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-primary/5 to-transparent pointer-events-none" />
		
		<div class="max-w-7xl mx-auto relative z-10">
			{/* Header */}
			<div class="mb-20 pt-8 max-w-3xl">
				<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 text-foreground text-deep-shadow">
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-foreground to-foreground/70 text-deep-shadow">
						Engineering
					</span>
					<br />
					<span class="text-primary text-deep-shadow">Logbook</span>
				</h1>
				<p class="text-xl text-muted-foreground leading-relaxed">
					Tracking progress across time cycles. From <span class="text-foreground font-medium">daily notes</span> to <span class="text-foreground font-medium">5-year visions</span>.
				</p>
			</div>

			<JournalContent client:load initialLogs={mappedLogs} />
		</div>
	</main>
</BaseLayout>

<style>
	.text-deep-shadow {
		text-shadow: 0 0 40px rgba(var(--primary), 0.2);
	}
</style>
